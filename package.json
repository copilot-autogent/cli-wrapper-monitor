{
  "name": "cli-wrapper-monitor",
  "version": "1.0.0",
  "description": "Regression detection for Copilot CLI wrapper behavior",
  "type": "module",
  "scripts": {
    "experiments": "npx tsx scripts/run-experiments.ts",
    "capture": "npx tsx scripts/capture-autogent-baseline.ts",
    "diff": "npx tsx scripts/generate-diff-report.ts",
    "compare": "npx tsx scripts/compare-baselines.ts",
    "trend": "npx tsx scripts/trend-report.ts",
    "chart": "npx tsx scripts/generate-chart.ts",
    "multi-model": "npx tsx scripts/capture-multi-model.ts",
    "validate": "npx tsx scripts/validate-baselines.ts",
    "migrate": "npx tsx scripts/migrate-baselines.ts",
    "archive": "npx tsx scripts/archive-baselines.ts",
    "health": "npx tsx scripts/capture-health-report.ts",
    "dashboard": "npx tsx scripts/generate-dashboard.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "preflight": "npx tsx scripts/preflight.ts",
    "check-staleness": "npx tsx scripts/check-capture-staleness.ts",
    "export": "npx tsx scripts/export-metrics.ts"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "vitest": "^4.1.9"
  }
}
