{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/copilot-autogent/cli-wrapper-monitor/blob/main/baselines/schema.json",
  "title": "MetricSnapshot",
  "description": "A snapshot of CLI wrapper monitor experiment results at a point in time",
  "type": "object",
  "required": ["capturedAt", "monitorVersion", "sdkVersion", "model", "experiments"],
  "additionalProperties": false,
  "properties": {
    "capturedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the snapshot was captured"
    },
    "monitorVersion": {
      "type": "string",
      "description": "Short git SHA of the monitor repo at capture time, or 'unknown'"
    },
    "sdkVersion": {
      "type": "string",
      "description": "@github/copilot-sdk semver constraint from package.json"
    },
    "model": {
      "type": "string",
      "description": "Copilot model identifier used during experiments"
    },
    "experiments": {
      "type": "object",
      "description": "Experiment results, keyed by experiment name",
      "additionalProperties": {
        "$ref": "#/$defs/ExperimentResult"
      }
    }
  },
  "$defs": {
    "ExperimentResult": {
      "type": "object",
      "required": ["name", "description", "metrics"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Experiment identifier"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of what the experiment measures"
        },
        "metrics": {
          "type": "object",
          "description": "Named metric values",
          "additionalProperties": {
            "$ref": "#/$defs/MetricValue"
          }
        },
        "rawData": {
          "description": "Optional raw data preserved for debugging"
        },
        "error": {
          "type": "string",
          "description": "Error message if the experiment failed to run"
        }
      }
    },
    "MetricValue": {
      "type": "object",
      "required": ["value", "unit", "description"],
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": "number",
          "description": "Numeric measurement"
        },
        "unit": {
          "type": "string",
          "description": "Unit of measurement (e.g. 'chars', 'tokens', 'fraction', 'count')"
        },
        "description": {
          "type": "string",
          "description": "What this metric measures"
        }
      }
    }
  }
}
